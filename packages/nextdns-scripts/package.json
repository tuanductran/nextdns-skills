{
  "name": "nextdns-skills-scripts",
  "version": "1.0.0",
  "description": "Maintenance scripts for NextDNS Skills: validate rule integrity, sync counts, check duplicates/tags, and generate stats",
  "type": "module",
  "bin": {
    "nextdns-skills-scripts": "./bin/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "validate-rules": "node bin/cli.js validate-rules",
    "update-counts": "node bin/cli.js update-counts",
    "dev": "tsup --watch",
    "check-duplicates": "node bin/cli.js check-duplicates",
    "check-tags": "node bin/cli.js check-tags",
    "generate-stats": "node bin/cli.js generate-stats",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "nextdns",
    "skills",
    "scripts",
    "validation",
    "maintenance"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  }
}

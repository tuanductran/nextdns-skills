{
  "name": "nextdns-skills-scripts",
  "version": "1.0.0",
  "description": "Maintenance scripts for NextDNS Skills: validate rule integrity, sync counts, check duplicates/tags, and generate stats",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "types:check": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "validate-rules": "node dist/validate-rules.js",
    "update-counts": "node dist/update-counts.js",
    "check-duplicates": "node dist/check-duplicates.js",
    "check-tags": "node dist/check-tags.js",
    "generate-stats": "node dist/generate-stats.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "nextdns",
    "skills",
    "scripts",
    "validation",
    "maintenance"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  }
}

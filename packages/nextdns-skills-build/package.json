{
  "name": "nextdns-skills-build",
  "version": "1.0.0",
  "description": "Build tooling for NextDNS Skills: build AGENTS.md, validate, scaffold rules, search, and export",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./build": {
      "types": "./dist/build.d.ts",
      "import": "./dist/build.js"
    },
    "./validate": {
      "types": "./dist/validate.d.ts",
      "import": "./dist/validate.js"
    },
    "./search": {
      "types": "./dist/search.d.ts",
      "import": "./dist/search.js"
    },
    "./export": {
      "types": "./dist/export.d.ts",
      "import": "./dist/export.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "types:check": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "build-agents": "node dist/build.js",
    "build-all": "node dist/build.js --all",
    "build-api": "node dist/build.js --skill=nextdns-api",
    "build-cli": "node dist/build.js --skill=nextdns-cli",
    "build-ui": "node dist/build.js --skill=nextdns-ui",
    "build-integrations": "node dist/build.js --skill=integrations",
    "build-frontend": "node dist/build.js --skill=nextdns-frontend",
    "validate": "node dist/validate.js",
    "extract-tests": "node dist/extract-tests.js",
    "migrate": "node dist/migrate.js",
    "search": "node dist/search.js",
    "export": "node dist/export.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "nextdns",
    "dns",
    "skills",
    "guidelines",
    "llm",
    "agents"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  }
}

{
  "name": "nextdns-skills",
  "version": "1.0.0",
  "description": "Comprehensive AI agent skills for NextDNS management, covering API integration, CLI operations, and Web UI configuration best practices.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuanductran/nextdns-skills.git"
  },
  "homepage": "https://github.com/tuanductran/nextdns-skills#readme",
  "bugs": {
    "url": "https://github.com/tuanductran/nextdns-skills/issues"
  },
  "author": "Tuan Duc Tran <tuanductran.dev@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "nextdns",
    "dns",
    "security",
    "privacy",
    "parental-control",
    "ddns",
    "denylist",
    "allowlist",
    "analytics",
    "logs",
    "configuration",
    "threat-modeling",
    "setup-optimization",
    "troubleshooting",
    "api",
    "cli",
    "ui",
    "agent-skills",
    "ai-agent"
  ],
  "scripts": {
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "pnpm run format:check && pnpm run \"/^lint:(md|rules|syntax)$/\"",
    "lint:all": "pnpm run lint && pnpm run lint:links",
    "lint:fix": "pnpm run format && pnpm run lint:md:fix && pnpm run lint:syntax:fix && pnpm run lint:rules",
    "lint:links": "find . -name \"*.md\" -not -path \"*/node_modules/*\" -not -path \"*/templates/*\" | xargs markdown-link-check -c config.json",
    "lint:md": "markdownlint .",
    "lint:md:fix": "markdownlint . --fix",
    "lint:rules": "nextdns-skills-scripts validate-rules",
    "lint:syntax": "case-police \"skills/**/rules/**/*.md\"",
    "lint:syntax:fix": "case-police --fix \"skills/**/rules/**/*.md\"",
    "build": "turbo build",
    "build:skills": "nextdns-skills-build build --all",
    "build:api": "nextdns-skills-build build --skill=nextdns-api",
    "build:cli": "nextdns-skills-build build --skill=nextdns-cli",
    "build:ui": "nextdns-skills-build build --skill=nextdns-ui",
    "build:integrations": "nextdns-skills-build build --skill=integrations",
    "build:frontend": "nextdns-skills-build build --skill=nextdns-frontend",
    "update-counts": "nextdns-skills-scripts update-counts",
    "dev": "turbo dev",
    "check-duplicates": "nextdns-skills-scripts check-duplicates",
    "check-tags": "nextdns-skills-scripts check-tags",
    "stats": "nextdns-skills-scripts generate-stats --text",
    "lint:quality": "pnpm run check-duplicates && pnpm run check-tags",
    "rule-search": "nextdns-skills-build search",
    "rule-export": "nextdns-skills-build export"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "case-police": "^2.1.1",
    "markdown-link-check": "^3.14.2",
    "markdownlint-cli": "^0.48.0",
    "nextdns-skills-build": "workspace:*",
    "nextdns-skills-scripts": "workspace:*",
    "turbo": "^2.8.12"
  },
  "pnpm": {
    "overrides": {
      "minimatch": ">=10.2.3"
    }
  }
}
